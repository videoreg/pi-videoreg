#!/bin/bash
# Tails the log file for a given plugin. Usage: vrg-log PLUGIN_NAME [LINES]

set -e  # Stop execution on error

# Output colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

show_usage() {
    echo "Usage: vrg-log PLUGIN_NAME [LINES]"
    echo ""
    echo "Parameters:"
    echo "  PLUGIN_NAME  Plugin name (required)"
    echo "  LINES        Number of lines to show (optional, default: 300)"
    echo ""
    echo "Examples:"
    echo "  vrg-log service_power"
    echo "  vrg-log service_power 500"
    echo "  vrg-log service_bot 1000"
}

check_project_home() {
    if [[ -z "$VIDEOREG_PROJECT_HOME" ]]; then
        print_error "VIDEOREG_PROJECT_HOME environment variable is not set"
        print_error "Set it with: source tools/init.sh"
        exit 1
    fi

    if [[ ! -d "$VIDEOREG_PROJECT_HOME" ]]; then
        print_error "Project directory does not exist: $VIDEOREG_PROJECT_HOME"
        exit 1
    fi
}

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    show_usage
    exit 0
fi

if [[ -z "$1" ]]; then
    print_error "PLUGIN_NAME is required"
    echo ""
    show_usage
    exit 1
fi

PLUGIN_NAME="$1"
LINES="${2:-300}"

check_project_home

LOGS_DIR="$VIDEOREG_PROJECT_HOME/.videoreg/log/plugins"
LOG_FILE="$LOGS_DIR/org_vrg_${PLUGIN_NAME}.log"

if [[ ! -f "$LOG_FILE" ]]; then
    print_error "Log file not found: $LOG_FILE"
    exit 1
fi

print_info "Log file: $LOG_FILE"
print_info "Lines: $LINES"
echo ""

tail -n "$LINES" "$LOG_FILE"
