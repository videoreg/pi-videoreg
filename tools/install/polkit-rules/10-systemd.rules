polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        subject.user == "$VIDEOREG_USER") {
        var unit = action.lookup("unit");
        // Allow to configure all services, which name starts with "vrg-"
        // Разрешаем управление всеми сервисами, начинающимися с "vrg-"
        if (unit && unit.indexOf("vrg-") == 0) {
            return polkit.Result.YES;
        }
    }
});
