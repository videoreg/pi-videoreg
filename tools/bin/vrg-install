#!/bin/bash
# Installs and configures the videoreg system: creates user/group, installs APT packages and Python deps,
# sets up systemd services, polkit rules, sudoers, mediamtx, PiSugar shutdown hook, and config.json.
# Intended to be run during OS image creation (not on a live device).
# Must be run as root. Requires VIDEOREG_PROJECT_HOME to be set (source tools/init.sh).

set -e  # Stop execution on error

# Output colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Command-line parameter variables
PARAM_USER=""
PARAM_GROUP=""
PARAM_STORAGE_PATH=""

# Output helpers
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_header() {
    echo -e "${BLUE}================================${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}================================${NC}"
}

show_help() {
    cat << EOF
Usage: vrg-install --user USER --group GROUP [OPTIONS]

Installs and configures the videoreg system.

REQUIRED OPTIONS:
  --user USER              Username for files and directories ownership
  --group GROUP            Group name for files and directories ownership

OPTIONAL OPTIONS:
  --storage-path PATH      Path for media storage (h264, mp4, jpeg, gps subdirs created automatically)
  -h, --help               Show this help and exit

EXAMPLES:
  sudo vrg-install --user pi --group pi
  sudo vrg-install --user pi --group pi --storage-path /mnt/sdcard

NOTES:
  - Must be run as root (sudo)
  - VIDEOREG_PROJECT_HOME must be set (source tools/init.sh)
  - User and group will be created if they do not exist

EOF
    exit 0
}

parse_arguments() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --user)
                PARAM_USER="$2"
                shift 2
                ;;
            --group)
                PARAM_GROUP="$2"
                shift 2
                ;;
            --storage-path)
                PARAM_STORAGE_PATH="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                ;;
            *)
                print_error "Unknown parameter: $1"
                echo "Use --help for usage information"
                exit 1
                ;;
        esac
    done
}

check_root() {
    if [[ $EUID -ne 0 ]]; then
        print_error "This script must be run as root (sudo)"
        exit 1
    fi
}

check_project_home() {
    if [[ -z "$VIDEOREG_PROJECT_HOME" ]]; then
        print_error "VIDEOREG_PROJECT_HOME environment variable is not set"
        print_error "Set it with: source tools/init.sh"
        exit 1
    fi

    if [[ ! -d "$VIDEOREG_PROJECT_HOME" ]]; then
        print_error "Project directory does not exist: $VIDEOREG_PROJECT_HOME"
        exit 1
    fi

    print_info "Project path: $VIDEOREG_PROJECT_HOME"
}

choose_user_and_group() {
    if [[ -z "$PARAM_USER" || -z "$PARAM_GROUP" ]]; then
        print_error "--user and --group are required"
        echo "Use --help for usage information"
        exit 1
    fi

    VIDEOREG_USER="$PARAM_USER"
    VIDEOREG_GROUP="$PARAM_GROUP"

    print_info "User: '$VIDEOREG_USER', group: '$VIDEOREG_GROUP'"

    if ! id "$VIDEOREG_USER" &>/dev/null; then
        print_warning "User '$VIDEOREG_USER' does not exist, creating..."

        if ! getent group "$VIDEOREG_GROUP" &>/dev/null; then
            print_info "Creating group: $VIDEOREG_GROUP"
            if groupadd "$VIDEOREG_GROUP"; then
                print_success "Group '$VIDEOREG_GROUP' created"
            else
                print_error "Failed to create group '$VIDEOREG_GROUP'"
                exit 1
            fi
        fi

        if useradd -g "$VIDEOREG_GROUP" -m "$VIDEOREG_USER"; then
            print_success "User '$VIDEOREG_USER' created"
        else
            print_error "Failed to create user '$VIDEOREG_USER'"
            exit 1
        fi
    else
        if ! getent group "$VIDEOREG_GROUP" &>/dev/null; then
            print_error "Group '$VIDEOREG_GROUP' does not exist"
            exit 1
        fi
        print_success "User '$VIDEOREG_USER' and group '$VIDEOREG_GROUP' exist"
    fi
}

check_rpicam_utilities() {
    print_info "Checking for rpicam-vid..."
    if ! command -v rpicam-vid &> /dev/null; then
        print_error "rpicam-vid not found in the system"
        exit 1
    fi
    print_success "rpicam-vid found"

    print_info "Checking for rpicam-jpeg..."
    if ! command -v rpicam-jpeg &> /dev/null; then
        print_error "rpicam-jpeg not found in the system"
        exit 1
    fi
    print_success "rpicam-jpeg found"

    print_success "All required rpicam utilities are installed"
}

install_apt_packages() {
    APT_PACKAGES=(
        "ffmpeg"
        "minicom"
        "libqmi-utils"
        "udhcpc"
        "netcat-openbsd"
        "i2c-tools"
        "resolvconf"
        "wireguard"
        "wireguard-tools"
        "python3-dbus"
        "python3-venv"
        "python3-netifaces"
    )

    print_info "Updating package list..."
    apt-get update

    print_info "Installing packages: ${APT_PACKAGES[*]}"
    if apt-get install -y "${APT_PACKAGES[@]}"; then
        print_success "All packages installed successfully"
    else
        print_error "Failed to install packages"
        exit 1
    fi

    print_info "Marking packages as manually installed (prevents autoremove)..."
    apt-mark manual "${APT_PACKAGES[@]}"
    print_success "Packages marked as manually installed"
}

setup_venv() {
    VENV_DIR="$VIDEOREG_PROJECT_HOME/.venv"
    REQUIREMENTS_FILE="$VIDEOREG_PROJECT_HOME/requirements.txt"

    if [[ ! -f "$REQUIREMENTS_FILE" ]]; then
        print_error "Requirements file not found: $REQUIREMENTS_FILE"
        exit 1
    fi

    print_info "Creating virtual environment: $VENV_DIR"
    if python3 -m venv --system-site-packages "$VENV_DIR"; then
        print_success "Virtual environment created"
    else
        print_error "Failed to create virtual environment"
        exit 1
    fi

    print_info "Installing Python dependencies from $REQUIREMENTS_FILE..."
    if "$VENV_DIR/bin/pip" install --upgrade pip --quiet && \
       "$VENV_DIR/bin/pip" install -r "$REQUIREMENTS_FILE"; then
        print_success "Python dependencies installed"
    else
        print_error "Failed to install Python dependencies"
        exit 1
    fi

    print_info "Setting venv ownership..."
    chown -R "$VIDEOREG_USER:$VIDEOREG_GROUP" "$VENV_DIR"
    print_success "Virtual environment configured"
}

install_mediamtx() {
    MEDIAMTX_VERSION="v1.15.1"
    MEDIAMTX_URL="https://github.com/bluenviron/mediamtx/releases/download/${MEDIAMTX_VERSION}/mediamtx_${MEDIAMTX_VERSION}_linux_arm64.tar.gz"
    TEMP_DIR=$(mktemp -d)

    print_info "Downloading mediamtx ${MEDIAMTX_VERSION}..."

    if wget -q -O "$TEMP_DIR/mediamtx.tar.gz" "$MEDIAMTX_URL"; then
        print_success "mediamtx archive downloaded"
    else
        print_error "Failed to download mediamtx"
        rm -rf "$TEMP_DIR"
        exit 1
    fi

    print_info "Extracting archive..."
    if tar -xzf "$TEMP_DIR/mediamtx.tar.gz" -C "$TEMP_DIR"; then
        print_success "Archive extracted"
    else
        print_error "Failed to extract mediamtx archive"
        rm -rf "$TEMP_DIR"
        exit 1
    fi

    print_info "Installing mediamtx to /usr/local/bin/..."
    if cp "$TEMP_DIR/mediamtx" /usr/local/bin/mediamtx; then
        chmod +x /usr/local/bin/mediamtx
        print_success "mediamtx installed to /usr/local/bin/"
    else
        print_error "Failed to copy mediamtx to /usr/local/bin/"
        rm -rf "$TEMP_DIR"
        exit 1
    fi

    print_info "Cleaning up temporary files..."
    rm -rf "$TEMP_DIR"
    print_success "Temporary files removed"

    if command -v mediamtx &> /dev/null; then
        print_success "mediamtx is installed and available in PATH"
    else
        print_error "mediamtx was installed but not found in PATH"
        exit 1
    fi
}

setup_systemd_services() {
    SERVICES_SOURCE_DIR="$VIDEOREG_PROJECT_HOME/tools/install/services"
    SYSTEMD_DIR="/etc/systemd/system"

    print_info "Copying services from $SERVICES_SOURCE_DIR"

    if [[ ! -d "$SERVICES_SOURCE_DIR" ]]; then
        print_error "Services directory not found: $SERVICES_SOURCE_DIR"
        exit 1
    fi

    COPIED_SERVICES=()

    for service_file in "$SERVICES_SOURCE_DIR"/*.service "$SERVICES_SOURCE_DIR"/*.target; do
        if [[ -f "$service_file" ]]; then
            service_name=$(basename "$service_file")
            print_info "Copying service: $service_name"

            temp_service_file=$(mktemp)
            sed -e "s|\$VIDEOREG_PROJECT_HOME|$VIDEOREG_PROJECT_HOME|g" \
                -e "s|\$VIDEOREG_USER|$VIDEOREG_USER|g" \
                -e "s|\$VIDEOREG_GROUP|$VIDEOREG_GROUP|g" \
                "$service_file" > "$temp_service_file"

            cp "$temp_service_file" "$SYSTEMD_DIR/$service_name"
            chmod 644 "$SYSTEMD_DIR/$service_name"
            rm "$temp_service_file"

            service_name_clean="$service_name"
            COPIED_SERVICES+=("$service_name_clean")

            print_success "Service $service_name copied"
        fi
    done

    if [[ ${#COPIED_SERVICES[@]} -eq 0 ]]; then
        print_warning "No .service files found in $SERVICES_SOURCE_DIR"
    else
        print_info "Reloading systemd daemon..."
        systemctl daemon-reload

        print_info "Enabling services for autostart..."
        for service in "${COPIED_SERVICES[@]}"; do
            print_info "Enabling service: $service"
            if systemctl enable "$service"; then
                print_success "Service $service enabled"
            else
                print_warning "Failed to enable service $service"
            fi
        done

        print_success "Services configured and enabled"
    fi
}

setup_polkit_rules() {
    POLKIT_RULES_SOURCE_DIR="$VIDEOREG_PROJECT_HOME/tools/install/polkit-rules"
    POLKIT_RULES_TARGET_DIR="/etc/polkit-1/rules.d"

    print_info "Copying polkit rules from $POLKIT_RULES_SOURCE_DIR"

    if [[ ! -d "$POLKIT_RULES_SOURCE_DIR" ]]; then
        print_error "Polkit rules directory not found: $POLKIT_RULES_SOURCE_DIR"
        exit 1
    fi

    mkdir -p "$POLKIT_RULES_TARGET_DIR"

    for rules_file in "$POLKIT_RULES_SOURCE_DIR"/*.rules; do
        if [[ -f "$rules_file" ]]; then
            rules_name=$(basename "$rules_file")
            print_info "Copying polkit rule: $rules_name"

            temp_rules_file=$(mktemp)
            sed "s|\$VIDEOREG_USER|$VIDEOREG_USER|g" "$rules_file" | \
            sed "s|\$VIDEOREG_GROUP|$VIDEOREG_GROUP|g" > "$temp_rules_file"

            cp "$temp_rules_file" "$POLKIT_RULES_TARGET_DIR/$rules_name"
            chmod 644 "$POLKIT_RULES_TARGET_DIR/$rules_name"
            rm "$temp_rules_file"

            print_success "Polkit rule $rules_name copied"
        fi
    done

    print_success "Polkit rules configured"
}

setup_bluetooth() {
    print_info "Setting bluetooth supervision timeout..."
    if sudo echo '500' | sudo tee /sys/kernel/debug/bluetooth/hci0/supervision_timeout > /dev/null 2>&1; then
        print_success "Bluetooth supervision timeout set to 500"
    else
        print_warning "Could not set bluetooth supervision timeout (bluetooth may be inactive)"
    fi
}

create_videoreg_directory() {
    VIDEOREG_DIR="$VIDEOREG_PROJECT_HOME/.videoreg"

    print_info "Creating directory: $VIDEOREG_DIR"
    mkdir -p "$VIDEOREG_DIR"
    mkdir -p "$VIDEOREG_DIR/log"
    mkdir -p "$VIDEOREG_DIR/data"

    print_info "Setting ownership to $VIDEOREG_USER:$VIDEOREG_GROUP"
    chown -R "$VIDEOREG_USER:$VIDEOREG_GROUP" "$VIDEOREG_DIR"

    print_success "Directories created: $VIDEOREG_DIR, $VIDEOREG_DIR/log, $VIDEOREG_DIR/data"
}

setup_storage_paths() {
    if [[ -n "$PARAM_STORAGE_PATH" ]]; then
        print_info "Using storage path from parameter: $PARAM_STORAGE_PATH"

        if [[ ! -d "$PARAM_STORAGE_PATH" ]]; then
            print_warning "Directory does not exist: $PARAM_STORAGE_PATH"
            print_warning "Subdirectories will not be created. Make sure the directory is created later."
        else
            mkdir -p "$PARAM_STORAGE_PATH/jpeg" "$PARAM_STORAGE_PATH/h264" "$PARAM_STORAGE_PATH/mp4" "$PARAM_STORAGE_PATH/gps"
            chown -R "$VIDEOREG_USER:$VIDEOREG_GROUP" "$PARAM_STORAGE_PATH" 2>/dev/null || true
            print_success "Subdirectories created in: $PARAM_STORAGE_PATH"
        fi

        JPEG_PATH="$PARAM_STORAGE_PATH/jpeg"
        H264_PATH="$PARAM_STORAGE_PATH/h264"
        MP4_PATH="$PARAM_STORAGE_PATH/mp4"
        GPS_PATH="$PARAM_STORAGE_PATH/gps"
    else
        print_info "Files will be stored in project directory: $VIDEOREG_DIR"

        JPEG_PATH="$VIDEOREG_DIR/jpeg"
        H264_PATH="$VIDEOREG_DIR/h264"
        MP4_PATH="$VIDEOREG_DIR/mp4"
        GPS_PATH="$VIDEOREG_DIR/gps"
    fi

    print_info "Configured paths:"
    print_info "  - JPEG: $JPEG_PATH"
    print_info "  - H264: $H264_PATH"
    print_info "  - MP4: $MP4_PATH"
    print_info "  - GPS: $GPS_PATH"
}

setup_pisugar_shutdown() {
    SHUTDOWN_SCRIPT_SOURCE="$VIDEOREG_PROJECT_HOME/tools/install/shutdown-pisugar.sh"
    SHUTDOWN_TARGET_DIR="/lib/systemd/system-shutdown"

    print_info "Installing PiSugar shutdown script..."

    if [[ ! -f "$SHUTDOWN_SCRIPT_SOURCE" ]]; then
        print_error "Script not found: $SHUTDOWN_SCRIPT_SOURCE"
        exit 1
    fi

    mkdir -p "$SHUTDOWN_TARGET_DIR"

    if cp "$SHUTDOWN_SCRIPT_SOURCE" "$SHUTDOWN_TARGET_DIR/shutdown-pisugar.sh"; then
        chmod +x "$SHUTDOWN_TARGET_DIR/shutdown-pisugar.sh"
        print_success "Script copied to $SHUTDOWN_TARGET_DIR/shutdown-pisugar.sh"
    else
        print_error "Failed to copy script to $SHUTDOWN_TARGET_DIR"
        exit 1
    fi
}

setup_sudoers() {
    SUDOERS_SOURCE="$VIDEOREG_PROJECT_HOME/tools/install/sudoers"
    SUDOERS_TARGET="/etc/sudoers.d/99-videoreg"

    print_info "Creating sudoers file: $SUDOERS_TARGET"

    if [[ ! -f "$SUDOERS_SOURCE" ]]; then
        print_error "Source sudoers file not found: $SUDOERS_SOURCE"
        exit 1
    fi

    if cp "$SUDOERS_SOURCE" "$SUDOERS_TARGET"; then
        print_success "sudoers file copied: $SUDOERS_TARGET"
    else
        print_error "Failed to copy sudoers file"
        exit 1
    fi

    print_info "Replacing VIDEOREG_USER with '$VIDEOREG_USER' in sudoers..."
    if sed -i "s/VIDEOREG_USER/$VIDEOREG_USER/g" "$SUDOERS_TARGET"; then
        print_success "VIDEOREG_USER replaced with '$VIDEOREG_USER'"
    else
        print_error "Failed to replace VIDEOREG_USER in sudoers"
        rm -f "$SUDOERS_TARGET"
        exit 1
    fi

    chmod 440 "$SUDOERS_TARGET"
    chown root:root "$SUDOERS_TARGET"

    print_info "Validating sudoers syntax..."
    if visudo -c -f "$SUDOERS_TARGET"; then
        print_success "sudoers syntax is valid"
    else
        print_error "sudoers syntax error"
        print_error "Removing invalid file..."
        rm -f "$SUDOERS_TARGET"
        exit 1
    fi

    print_success "sudoers configured"
}

parse_arguments "$@"

print_header "VIDEOREG INSTALLATION SCRIPT"

check_root
check_project_home

print_header "1. USER AND GROUP"
choose_user_and_group

print_header "2. RPICAM UTILITIES CHECK"
check_rpicam_utilities

print_header "3. APT PACKAGES"
install_apt_packages

print_header "4. VIRTUAL ENVIRONMENT (VENV)"
setup_venv

print_header "5. MEDIAMTX"
install_mediamtx

print_header "6. SYSTEMD SERVICES"
setup_systemd_services

print_header "7. POLKIT RULES"
setup_polkit_rules

print_header "8. PISUGAR SHUTDOWN SCRIPT"
setup_pisugar_shutdown

print_header "9. BLUETOOTH"
setup_bluetooth

print_header "10. CONFIGURATION DIRECTORY"
create_videoreg_directory

print_header "11. STORAGE PATHS"
setup_storage_paths

print_header "12. SUDOERS"
setup_sudoers

print_success "Videoreg installed successfully!"
