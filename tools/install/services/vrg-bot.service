[Unit]
Description=Videoreg Bot
After=vrg-network.target
PartOf=vrg-network.target

[Service]
User=$VIDEOREG_USER
Group=$VIDEOREG_GROUP
ExecStart=bash $VIDEOREG_PROJECT_HOME/task/service/vrg-bot.sh --videoreg-project-home $VIDEOREG_PROJECT_HOME
Type=simple
Restart=always
TimeoutStopSec=4

[Install]
WantedBy=vrg-network.target