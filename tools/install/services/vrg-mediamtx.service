[Unit]
Description=Videoreg Mediamtx
After=vrg-charging.target
PartOf=vrg-charging.target

[Service]
User=$VIDEOREG_USER
Group=$VIDEOREG_GROUP
ExecStart=bash $VIDEOREG_PROJECT_HOME/task/service/vrg-mediamtx.sh --videoreg-project-home $VIDEOREG_PROJECT_HOME
Type=simple
Restart=always
TimeoutStopSec=4

[Install]
WantedBy=vrg-charging.target